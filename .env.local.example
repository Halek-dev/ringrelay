# Ring Relay — environment variables
# Copy to .env.local and fill in from your Supabase project
# (Supabase dashboard → Project Settings → API).

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser or commit. Used only in
# server actions for privileged operations (creating team members) and by the
# /demo voice receptionist to save bookings.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Voice demo (/demo) — all server-side only ---
# Anthropic API key for the receptionist "brain" (Claude).
ANTHROPIC_API_KEY=sk-ant-your-key
# ElevenLabs text-to-speech for the receptionist voice.
ELEVENLABS_API_KEY=your-elevenlabs-key
# The ElevenLabs voice to speak in (Voices page → copy the voice ID).
ELEVENLABS_VOICE_ID=your-voice-id

# --- Transactional email (Resend) — all server-side only ---
# API key from resend.com. Without it, sends are skipped and logged; the app
# never breaks because email is not configured. Verify the sending domain in
# Resend first (add the SPF and DKIM DNS records it shows you).
RESEND_API_KEY=re_your-key
# Verified sender shown to recipients. The domain must be verified in Resend.
EMAIL_FROM="Ring Relay <hello@tryringrelay.com>"
# Where applicant replies land (your real inbox).
EMAIL_REPLY_TO=tryringrelay@gmail.com

# Optional — used in metadata/robots/sitemap. Defaults to the placeholder.
# NEXT_PUBLIC_SITE_URL=https://ringrelay.com
